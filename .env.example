# Copy to .env and fill in. (.env is gitignored — never commit real keys.)
# ---------------------------------------------------------------------------

# Master demo switch. "mock" = every external call (Tavily, the paid vendor,
# the chain, Coinbase tracing) uses a cached fixture. The demo completes with
# NO network. Default "live" tries real calls and falls back to mock on error.
DEMO_MODE=live

# --- Grounding research (https://app.tavily.com -> API Keys) ----------------
TAVILY_API_KEY=tvly-...
# Legacy per-tool override (kept for the existing smoke test). DEMO_MODE=mock
# forces this on regardless.
MOCK_TAVILY=0

# --- Agent wallet (Base Sepolia TESTNET ONLY) -------------------------------
# A single secp256k1 key that BOTH pays the x402 micropayment AND signs the
# Passport. "A wallet is PKI, applied to an artwork's identity."
# Generate one with:  npm run wallet -- --new
# Fund it with test USDC: https://faucet.circle.com (Base Sepolia)
WALLET_PRIVATE_KEY=0x...

# Base Sepolia RPC (public default works; override for reliability on stage)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- x402 vendor service ----------------------------------------------------
# Where the agent reaches the paywalled "ALR Premium Search" vendor.
VENDOR_URL=http://localhost:4021
# Price the vendor charges per premium check (USD; x402 maps to USDC).
VENDOR_PRICE=0.05
# Address the vendor receives payment at. Defaults to the wallet address.
VENDOR_PAYTO=0x...

# x402 facilitator. Leave blank to use the public testnet facilitator
# (no Coinbase keys needed). Set to "coinbase" to settle via Coinbase CDP
# rails (requires CDP_API_KEY_ID + CDP_API_KEY_SECRET below).
X402_FACILITATOR=

# --- Coinbase CDP (optional: settlement + on-chain payment tracing) ---------
# If present, x402 settles via Coinbase and traceTransaction() screens the
# real on-chain transfer. If absent, the agent falls back to the public
# facilitator + a mocked trace. https://portal.cdp.coinbase.com
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# --- Agent reasoning budget -------------------------------------------------
# Hard cap (USD) the agent may spend on premium checks per run. Guardrail.
MAX_SPEND_USD=0.25

# --- ACLED data feed (optional) -------------------------------------------
# Paste the API key value from your ACLED JSON export here.
ACLED_API_KEY=
ACLED_API_URL=https://api.acleddata.com/acled/read
